{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kai",
  "version": "0.1.0",
  "identifier": "com.kai.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Kai",
        "width": 1280,
        "height": 860,
        "visible": false,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false,
        "decorations": false,
        "shadow": false,
        "transparent": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
